# Database Configuration
DATABASE_URL=sqlite:./data/blog.db

# Server Configuration
HOST=0.0.0.0
PORT=3006

# Authentication - REQUIRED IN PRODUCTION
# Generate strong secrets: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
BLOG_ADMIN_TOKEN=your-secret-admin-token-change-this-in-production-min-32-chars

# AI Service Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# CORS Configuration - REQUIRED IN PRODUCTION
# Add your frontend domain(s), e.g., https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Logging
RUST_LOG=info,cyrus_blog_backend=debug

# File Storage
UPLOAD_DIR=./uploads
BLOG_DATA_DIR=./data/blog

# S3-compatible Storage (Cloudflare R2)
S3_ENABLED=false
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=blog-assets
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=auto
S3_PUBLIC_URL=https://asset.blog.chuyi.uk

# WebAuthn (Passkey) — auto-derived from CORS_ORIGINS if not set
# WEBAUTHN_RP_ID=blog.chuyi.uk
# WEBAUTHN_RP_ORIGIN=https://blog.chuyi.uk
